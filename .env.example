# Diaricat Live — environment config
# Copy to .env and adjust as needed

# Server
DIARICAT_LIVE_HOST=127.0.0.1
DIARICAT_LIVE_PORT=8766

# Whisper
DIARICAT_LIVE_WHISPER_MODEL=large-v3
DIARICAT_LIVE_WHISPER_DEVICE=auto
DIARICAT_LIVE_WHISPER_COMPUTE_TYPE=float16
DIARICAT_LIVE_LANGUAGE=es

# Stream capture
DIARICAT_LIVE_BUFFER_DURATION_S=5.0
DIARICAT_LIVE_BUFFER_OVERLAP_S=1.0
DIARICAT_LIVE_FFMPEG_PATH=ffmpeg
DIARICAT_LIVE_YTDLP_PATH=yt-dlp

# Alerts
# DIARICAT_LIVE_ALERT_KEYWORDS_FILE=keywords.yaml

# Limits
DIARICAT_LIVE_MAX_SESSIONS=3
DIARICAT_LIVE_HEARTBEAT_INTERVAL_S=30
